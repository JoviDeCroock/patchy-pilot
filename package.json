{
  "name": "patchy-pilot",
  "version": "0.2.0",
  "description": "AI workflow harness: automatic review after AI coding sessions",
  "keywords": [
    "ai",
    "cli",
    "code-review",
    "workflow"
  ],
  "license": "MIT",
  "bin": {
    "ppilot": "./dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "patchy-pilot.example.json",
    "package.json",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
